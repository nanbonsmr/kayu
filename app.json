{
  "expo": {
    "name": "Kayu",
    "slug": "kayu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.svg",
    "scheme": "kayu",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.svg",
      "resizeMode": "contain",
      "backgroundColor": "#080810"
    },
    "ios": {
      "bundleIdentifier": "com.kayu.photoeditor",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Kayu needs camera access to take photos for editing.",
        "NSPhotoLibraryUsageDescription": "Kayu needs gallery access to import and save photos.",
        "NSPhotoLibraryAddUsageDescription": "Kayu needs permission to save edited photos to your gallery.",
        "LSApplicationQueriesSchemes": ["kayu"]
      }
    },
    "android": {
      "package": "com.kayu.photoeditor",
      "versionCode": 1,
      "useNextNotificationFormat": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_MEDIA_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.svg",
        "backgroundColor": "#080810"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "kayu"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icon.svg"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "photosPermission": "Kayu needs access to your photos.",
          "cameraPermission": "Kayu needs access to your camera."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Kayu to save photos.",
          "savePhotosPermission": "Allow Kayu to save edited photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "06d9467a-e227-4181-94b0-0eb350aa31f2"
      }
    }
  }
}
