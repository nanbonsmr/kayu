# PixelForge AI — Environment Variables
# Copy this file to .env and fill in your API keys

# remove.bg API key — https://www.remove.bg/api
EXPO_PUBLIC_REMOVE_BG_KEY=your_remove_bg_key_here

# Replicate API key — https://replicate.com/account/api-tokens
EXPO_PUBLIC_REPLICATE_KEY=your_replicate_key_here

# DeepAI API key — https://deepai.org/dashboard
EXPO_PUBLIC_DEEPAI_KEY=your_deepai_key_here
